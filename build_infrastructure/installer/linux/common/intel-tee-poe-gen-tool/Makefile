include installConfig

PACKAGE_ROOT_FOLDER=pkgroot
PACKAGES=$(notdir $(wildcard $(PACKAGE_ROOT_FOLDER)/*))

.PHONY: default install 

default:

install: $(PACKAGES)	
	cd $(shell readlink -m $(DESTDIR)/$(PLATFORM_OWNERSHIP_ENDORSEMENT_TOOL_PACKAGE_PATH)/$(PLATFORM_OWNERSHIP_ENDORSEMENT_TOOL_PACKAGE_NAME)) 

$(PACKAGES):
	install -d $(shell readlink -m $(DESTDIR)/$(PLATFORM_OWNERSHIP_ENDORSEMENT_TOOL_PACKAGE_PATH)/$(PLATFORM_OWNERSHIP_ENDORSEMENT_TOOL_PACKAGE_NAME)) 
	cp -r $(PACKAGE_ROOT_FOLDER)/$@/* $(DESTDIR)/$(PLATFORM_OWNERSHIP_ENDORSEMENT_TOOL_PACKAGE_PATH)/$(PLATFORM_OWNERSHIP_ENDORSEMENT_TOOL_PACKAGE_NAME)

