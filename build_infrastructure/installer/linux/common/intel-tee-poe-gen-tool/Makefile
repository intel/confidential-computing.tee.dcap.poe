include installConfig

PACKAGE_ROOT_FOLDER=pkgroot
PACKAGES=$(notdir $(wildcard $(PACKAGE_ROOT_FOLDER)/*))

.PHONY: default install 

default:

install: $(PACKAGES)	
	cd $(shell readlink -m $(DESTDIR)/$(PLATFORM_OWNERSHIP_ENDORSEMENT_TOOL_PACKAGE_PATH)/$(PLATFORM_OWNERSHIP_ENDORSEMENT_TOOL_PACKAGE_NAME)) 

$(PACKAGES):
	install -d $(shell readlink -m $(DESTDIR)/$(PLATFORM_OWNERSHIP_ENDORSEMENT_TOOL_PACKAGE_PATH)/$(PLATFORM_OWNERSHIP_ENDORSEMENT_TOOL_PACKAGE_NAME)) 
	cp -r $(PACKAGE_ROOT_FOLDER)/$@/* $(DESTDIR)/$(PLATFORM_OWNERSHIP_ENDORSEMENT_TOOL_PACKAGE_PATH)/$(PLATFORM_OWNERSHIP_ENDORSEMENT_TOOL_PACKAGE_NAME)
	@# Restrict permissions: binary executable 0755, regular files 0644, directories 0755
	find $(DESTDIR)/$(PLATFORM_OWNERSHIP_ENDORSEMENT_TOOL_PACKAGE_PATH)/$(PLATFORM_OWNERSHIP_ENDORSEMENT_TOOL_PACKAGE_NAME) -type f -name 'poe-gen-tool' -exec chmod 0755 {} +
	find $(DESTDIR)/$(PLATFORM_OWNERSHIP_ENDORSEMENT_TOOL_PACKAGE_PATH)/$(PLATFORM_OWNERSHIP_ENDORSEMENT_TOOL_PACKAGE_NAME) -type f ! -name 'poe-gen-tool' -exec chmod 0644 {} +
	find $(DESTDIR)/$(PLATFORM_OWNERSHIP_ENDORSEMENT_TOOL_PACKAGE_PATH)/$(PLATFORM_OWNERSHIP_ENDORSEMENT_TOOL_PACKAGE_NAME) -type d -exec chmod 0755 {} +

